package views

import (
	"plex-importor/internal/server"
	"plex-importor/internal/views/assets/js"
	"plex-importor/internal/views/assets/css"
	"plex-importor/internal/views/assets/images"
	"github.com/a-h/templ"
	"github.com/labstack/echo/v4"
)

templ Plex() {
	@Base() {
		<div class="container-fluid py-4">
			<h1 class="mb-4">Plex Video Importer</h1>

			<div class="row mb-4">
				<div class="col-md-6">
					<div class="card">
						<div class="card-body">
							<h5 class="card-title">Configuration</h5>
							<p class="card-text">
								Source: <span id="sourcePath"></span><br>
								Destination: <span id="destinationPath"></span>
							</p>
						</div>
					</div>
				</div>
			</div>

			<div class="row mb-4">
				<div class="col-12">
					<h2 class="mb-3">Folders with Video Files</h2>
					<div id="folderList" class="row">
						<div class="col-12 text-center py-5">
							<div class="spinner-border text-primary" role="status">
								<span class="visually-hidden">Loading...</span>
							</div>
							<p class="mt-3">Loading folders...</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Modal -->
		<div class="modal fade" id="metadataModal" tabindex="-1" aria-labelledby="metadataModalLabel" aria-hidden="true">
			<div class="modal-dialog modal-lg">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title" id="metadataModalLabel">Add Metadata</h5>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<div class="modal-body">
						<!-- Content Type Selection -->
						<div class="mb-4">
							<h6 class="mb-3">Content Type</h6>
							<div class="btn-group w-100" role="group">
								<input type="radio" class="btn-check" name="contentType" id="contentTypeMovie" value="movie" autocomplete="off">
								<label class="btn btn-outline-primary" for="contentTypeMovie">Movie</label>

								<input type="radio" class="btn-check" name="contentType" id="contentTypeTV" value="tv" autocomplete="off">
								<label class="btn btn-outline-primary" for="contentTypeTV">TV Show</label>
							</div>
						</div>

						<!-- Movie Form -->
						<div id="movieForm" class="mb-4">
							<h6 class="mb-3">Movie Details</h6>
							<div class="mb-3">
								<label for="movieTitle" class="form-label">Title</label>
								<input type="text" class="form-control" id="movieTitle" placeholder="Enter movie title">
							</div>
							<div class="mb-3">
								<label for="movieYear" class="form-label">Year of Release</label>
								<input type="number" class="form-control" id="movieYear" placeholder="2024" min="1900" max="2099">
							</div>
						</div>

						<!-- TV Show Form -->
						<div id="tvForm" class="mb-4" style="display: none;">
							<h6 class="mb-3">TV Show Details</h6>
							<div class="mb-3">
								<label for="tvSeries" class="form-label">Series Title</label>
								<select class="form-select" id="tvSeries">
									<option value="">Select a series...</option>
								</select>
								<div class="form-check mt-2">
									<input class="form-check-input" type="checkbox" id="newSeries">
									<label class="form-check-label" for="newSeries">
										Create new series
									</label>
								</div>
								<div id="newSeriesInput" class="mt-2" style="display: none;">
									<input type="text" class="form-control" id="newSeriesName" placeholder="Enter new series name">
								</div>
							</div>
							<div class="mb-3">
								<label for="tvSeason" class="form-label">Season</label>
								<input type="number" class="form-control" id="tvSeason" placeholder="1" min="1">
							</div>
							<div class="mb-3">
								<label for="tvEpisode" class="form-label">Episode</label>
								<input type="number" class="form-control" id="tvEpisode" placeholder="1" min="1">
							</div>
						</div>

						<input type="hidden" id="selectedFolder">
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
						<button type="button" class="btn btn-primary" id="submitMetadata">Submit</button>
					</div>
				</div>
			</div>
		</div>
	}
}

templ FolderCard(folderName, folderPath, videoFile string) {
	<div class="col-md-6 col-lg-4 mb-4">
		<div class="card h-100">
			<div class="card-body">
				<h5 class="card-title">{ folderName }</h5>
				<p class="card-text text-muted small">
					Path: { folderPath }
				</p>
				<p class="card-text">
					<i class="fas fa-video me-2"></i>
					{ videoFile }
				</p>
				<button class="btn btn-primary w-100" onclick="openMetadataModal('{ folderName }', '{ folderPath }', '{ videoFile }')">
					Add Metadata
				</button>
			</div>
		</div>
	</div>
}