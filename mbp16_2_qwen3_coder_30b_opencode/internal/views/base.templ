package views

templ Base() {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width,initial-scale=1"/>
			<title>Go Plex Import</title>
			<link rel="icon" href="images/favicon.png" type="image/png"/>
			<link href="css/site.css" rel="stylesheet"/>
			<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.8/css/bootstrap.min.css" integrity="sha512-2bBQCjcnw658Lho4nlXJcc6WkV/UxpE/sAokbXPxQNGqmNdQrWqtw26Ns9kFF/yG792pKR1Sx8/Y1Lf1XN4GKA==" crossorigin="anonymous" referrerpolicy="no-referrer"/>
			<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer"/>
			<script src="js/site.js"></script>
			<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.8/js/bootstrap.bundle.min.js" integrity="sha512-HvOjJrdwNpDbkGJIG2ZNqDlVqMo77qbs4Me4cah0HoDrfhrbA+8SBlZn1KrvAQw7cILLPFJvdwIgphzQmMm+Pw==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
			<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
			<script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.23.0/sweetalert2.all.min.js" integrity="sha512-J+4Nt/+nieSNJjQGCPb8jKf5/wv31QiQM10bOotEHUKc9tB1Pn0gXQS6XXPtDoQhHHao5poTnSByMInzafUqzA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
		</head>
		<body hx-ext="response-targets">
			<div class="theme-toggle-wrap">
				<button id="themeToggle" type="button" class="btn btn-outline-light btn-sm" aria-label="Toggle dark mode">
					<i class="fa-solid fa-moon"></i>
					<span id="themeToggleLabel">Dark</span>
				</button>
			</div>
			<main>
				{ children... }
			</main>
			<!-- HTML Templates -->
			<template id="type-selector-template">
				<div class="type-selector-container text-center">
					<h6 class="mb-3">Select Content Type</h6>
					<div class="btn-group w-100" role="group">
						<button type="button" class="btn btn-outline-primary" onclick="showMovieForm()">
							<div class="btn-content">
								<span class="btn-icon">🎬</span>
								<span class="btn-text">Movie</span>
							</div>
						</button>
						<button type="button" class="btn btn-outline-primary" onclick="showTVShowForm()">
							<div class="btn-content">
								<span class="btn-icon">📺</span>
								<span class="btn-text">TV Show</span>
							</div>
						</button>
					</div>
				</div>
			</template>

			<template id="movie-form-template">
				<form id="movie-form" onsubmit="handleSubmit(event)">
					<div class="mb-3">
						<label class="form-label">Movie Title *</label>
						<input type="text" class="form-control" id="movie-title" required placeholder="Enter movie title">
					</div>
					<div class="mb-3">
						<label class="form-label">Year *</label>
						<input type="number" class="form-control" id="movie-year" required placeholder="2024" min="1888" max="2100">
					</div>
					<input type="hidden" id="video-path" value="">
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
						<button type="submit" class="btn btn-primary" id="movie-submit-btn">Create</button>
					</div>
				</form>
			</template>

			<template id="tv-show-form-template">
				<form id="tv-show-form" onsubmit="handleSubmit(event)">
					<div class="mb-3">
						<label class="form-label">TV Show *</label>
						<select class="form-select" id="tv-show-select" required>
							<option value="">Select a TV show</option>
						</select>
						<div id="new-show-container" class="mt-2" style="display: none;">
							<input type="text" class="form-control" id="new-show-title" placeholder="Enter new show name">
						</div>
					</div>
					<div class="row">
						<div class="col-6 mb-3">
							<label class="form-label">Season *</label>
							<input type="number" class="form-control" id="season-number" required placeholder="1" min="1" max="999">
						</div>
						<div class="col-6 mb-3">
							<label class="form-label">Episode *</label>
							<input type="number" class="form-control" id="episode-number" required placeholder="1" min="1" max="999">
						</div>
					</div>
					<div class="mb-3">
						<label class="form-label">Episode Title</label>
						<input type="text" class="form-control" id="episode-title" placeholder="Auto-filled from filename">
					</div>
					<input type="hidden" id="video-path-tv" value="">
					<input type="hidden" id="is-new-show" value="false">
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
						<button type="submit" class="btn btn-primary" id="tv-submit-btn">Create</button>
					</div>
				</form>
			</template>
		</body>
	</html>
}
